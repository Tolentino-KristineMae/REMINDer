# Render.com — set the service Root Directory to `Rback` (this folder).
#
# Build order: Composer (vendor) → React build → copy SPA into public/ → migrate.
#
buildCommand: composer install --no-dev --optimize-autoloader && cd ../frontend && npm ci && npm run build && rm -rf ../Rback/public/assets && cp -r dist/. ../Rback/public/ && cd ../Rback && chmod +x build.sh && ./build.sh
startCommand: php artisan serve --host=0.0.0.0 --port=$PORT
envVars:
  - key: APP_KEY
    value: base64:/FJ4HHNRBbQbUBiAFXtQMahcxMls/JowqoEWrpzCCl0=
  - key: APP_ENV
    value: production
  - key: APP_DEBUG
    value: false
